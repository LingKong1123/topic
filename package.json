{
  "name": "ai-reading-timer",
  "version": "1.0.0",
  "description": "AI-powered reading timer with Pomodoro technique, task management, and learning analytics",
  "main": "electron/main.js",
  "homepage": "./",
  "private": true,
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "axios": "^1.6.0",
    "zustand": "^4.4.0",
    "recharts": "^2.10.0",
    "openai": "^4.26.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "electron": "^27.0.0",
    "electron-builder": "^24.0.0",
    "vite": "^5.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "tailwindcss": "^3.4.0",
    "postcss": "^8.4.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^8.0.0",
    "wait-on": "^7.0.0"
  },
  "scripts": {
    "dev": "concurrently \"npm run vite\" \"npm run electron\"",
    "vite": "vite",
    "electron": "wait-on http://localhost:5173 && electron .",
    "build": "vite build",
    "electron-dev": "electron . --no-sandbox",
    "dist": "npm run build && electron-builder",
    "type-check": "tsc --noEmit"
  },
  "keywords": ["pomodoro", "timer", "reading", "ai", "productivity", "learning"],
  "author": "Your Name",
  "license": "MIT"
}
